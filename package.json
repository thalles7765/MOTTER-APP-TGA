{
  "name": "medapp-store",
  "version": "0.0.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:medianeira": "ng serve --configuration medianeira",
    "start:robertopf": "ng serve --configuration robertopf",
    "start:mercandressa": "ng serve --configuration mercandressa",
    "start:hafam": "ng serve --configuration hafam",
    "start:eletroheloy": "ng serve --configuration eletroheloy",
    "build": "ng build",
    "build:medianeira": "ng build --configuration production",
    "build:robertopf": "ng build --configuration production,robertopf-production",
    "build:mercandressa": "ng build --configuration production,mercandressa-production",
    "build:hafam": "ng build --configuration production,hafam-production",
    "build:eletroheloy": "ng build --configuration production,eletroheloy-production",
    "check:jdk21": "node scripts/check-jdk21.js",
    "version:android-debug": "node scripts/bump-android-debug-version.js",
    "sync:android": "npm run check:jdk21 && npx cap sync android",
    "android:medianeira": "npm run version:android-debug -- medianeira && npm run build:medianeira && npm run sync:android && cd android && gradlew.bat assembleMedianeiraDebug",
    "android:robertopf": "npm run version:android-debug -- robertopf && npm run build:robertopf && npm run sync:android && cd android && gradlew.bat assembleRobertopfDebug",
    "android:mercandressa": "npm run version:android-debug -- mercandressa && npm run build:mercandressa && npm run sync:android && cd android && gradlew.bat assembleMercandressaDebug",
    "android:hafam": "npm run version:android-debug -- hafam && npm run build:hafam && npm run sync:android && cd android && gradlew.bat assembleHafamDebug",
    "android:eletroheloy": "npm run version:android-debug -- eletroheloy && npm run build:eletroheloy && npm run sync:android && cd android && gradlew.bat assembleEletroheloyDebug",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@capacitor-community/file-opener": "^8.0.0",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@ionic/angular": "^8.0.0",
    "axios": "^1.7.9",
    "bootstrap": "^5.3.3",
    "ionicons": "^7.0.0",
    "pdfmake": "^0.2.18",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular-eslint/builder": "^19.0.0",
    "@angular-eslint/eslint-plugin": "^19.0.0",
    "@angular-eslint/eslint-plugin-template": "^19.0.0",
    "@angular-eslint/schematics": "^19.0.0",
    "@angular-eslint/template-parser": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@angular/language-service": "^19.0.0",
    "@capacitor/cli": "^8.3.4",
    "@ionic/angular-toolkit": "^12.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/pdfmake": "^0.2.11",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.2.1",
    "eslint-plugin-prefer-arrow": "1.2.2",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.6.3"
  },
  "description": "An Ionic project"
}
